{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.{css,jsx,js,json,png,jpg,svg,ico,html,gif,woff,woff2}"]
  },
  "mimeTypes": {
    ".jsx": "application/javascript",
    ".json": "application/json"
  },
  "globalHeaders": {
    "Cache-Control": "no-cache",
    "Access-Control-Allow-Origin": "*"
  }
}
